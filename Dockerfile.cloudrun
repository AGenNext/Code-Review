FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# Copy project files
COPY pyproject.toml README.md ./
COPY src ./src

# Install with retry logic for network resilience
RUN pip install --upgrade pip && \
    pip install --retries 5 \
    'fastapi>=0.115.0' \
    'uvicorn>=0.30.0' \
    'pydantic>=2.8.0' \
    'anthropic>=0.39.0' \
    'opentelemetry-api>=1.29.0' \
    'opentelemetry-sdk>=1.29.0' \
    'opentelemetry-exporter-otlp-proto-http>=1.29.0' \
    'opentelemetry-instrumentation-fastapi>=0.50b0' || \
    pip install -e .

# Create non-root user and data directory
RUN useradd --create-home --uid 10001 appuser && \
    mkdir -p /data && \
    chown -R appuser:appuser /app /data

USER appuser

# Cloud Run requires port to be configurable via PORT env var
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD python -c "import os, urllib.request; urllib.request.urlopen(f'http://127.0.0.1:{os.getenv(\"PORT\", \"8080\")}/healthz', timeout=3).read()" || exit 1

CMD exec uvicorn codereviewer.api.app:app --host 0.0.0.0 --port ${PORT:-8080}
