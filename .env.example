# CodeReviewer environment template
# Do not store real secrets in this file.

# Runtime
PORT=8080
PYTHONPATH=/app/src

# Storage
CODEREVIEWER_DB_PATH=/data/codereviewer.db

# Provider/runtime defaults (set according to deployed service defaults)
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4

# Optional integrations (non-secret toggles)
LITELLM_ENABLED=false
MULTITENANCY_REQUIRE_AGENT_IDENTITY=false

# Secrets: set only in secret manager or platform secret UI
# CLAUDE_API_KEY=
# LITELLM_API_KEY=
# OTEL_EXPORTER_OTLP_ENDPOINT=
