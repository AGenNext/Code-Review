HOST=0.0.0.0
PORT=auto
PORT_START=8000
PORT_END=8999
APP_PORT=8000
CODEREVIEWER_DB_PATH=/data/codereviewer.db

SIGNOZ_ENABLED=false
SIGNOZ_SERVICE_NAME=code-reviewer
SIGNOZ_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

NOTIFICATIONS_ENABLED=false
NOTIFICATION_CHANNELS=email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

SSO_ENABLED=false
SSO_PROVIDER=oidc
SSO_ISSUER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_AUDIENCE=
SSO_REDIRECT_URI=
SSO_SCOPES=openid,profile,email

CLAUDE_AGENT_SDK_ENABLED=false
CLAUDE_AGENT_SDK_STRICT=false
CLAUDE_AGENT_SDK_MODEL=claude-sonnet-4
CLAUDE_AGENT_SDK_MAX_TOKENS=2048
CLAUDE_AGENT_SDK_TEMPERATURE=0.1
CLAUDE_API_KEY=

LITELLM_ENABLED=false
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=
LITELLM_MODEL=anthropic/claude-sonnet-4
LITELLM_PROVIDER_PREFIX_MAP={"anthropic":"anthropic/","vertex":"vertex_ai/","bedrock":"bedrock/","foundry":"azure/"}

MULTITENANCY_REQUIRE_AGENT_IDENTITY=false
